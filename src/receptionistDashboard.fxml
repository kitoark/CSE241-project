<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="700.0" prefWidth="1100.0" spacing="0" styleClass="root-vbox" stylesheets="@hotel.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ReceptionistController">

    <HBox alignment="CENTER_LEFT" prefHeight="70.0" spacing="20.0" styleClass="navbar">
        <padding>
            <Insets left="24" right="24" />
        </padding>
        <Label styleClass="nav-logo" text="🏨 GRAND HOTEL" />

        <HBox alignment="CENTER" spacing="10">
            <Button fx:id="btnRes" onAction="#showReservations" styleClass="nav-btn-active" text="📋 Reservations" />
            <Button fx:id="btnGuests" onAction="#showGuests" styleClass="nav-btn" text="👥 Guests" />
            <Button fx:id="btnRooms" onAction="#showRooms" styleClass="nav-btn" text="🛏 Rooms Status" />
            <Button onAction="#openNewReservation" styleClass="btn-primary" text="+ New Reservation" />
        </HBox>

        <Region HBox.hgrow="ALWAYS" />
        <VBox alignment="CENTER_RIGHT" spacing="2">
            <Label styleClass="nav-user" text="Front Desk Operations" />
            <Label fx:id="staffNameLabel" styleClass="nav-user" style="-fx-font-weight: bold;" text="Welcome, Receptionist" />
        </VBox>
        <Button onAction="#handleLogout" styleClass="btn-logout" text="Logout" />
    </HBox>

    <HBox spacing="0" VBox.vgrow="ALWAYS">
        <VBox prefWidth="280.0" spacing="15.0" styleClass="sidebar">
            <padding>
                <Insets bottom="24" left="20" right="20" top="24" />
            </padding>
            <VBox alignment="CENTER" spacing="5">
                <Label styleClass="page-title" text="Overview" />
                <Label styleClass="page-subtitle" text="Real-time Hotel Status" />
            </VBox>
            <Separator />
            <Label styleClass="sidebar-section-label" text="QUICK STATS" />
            <VBox spacing="4" styleClass="stat-card">
                <Label styleClass="stat-title" text="Total Guests" />
                <Label fx:id="statGuestsLabel" styleClass="stat-value" text="0" />
            </VBox>
            <VBox spacing="4" styleClass="stat-card">
                <Label styleClass="stat-title" text="Available Rooms" />
                <Label fx:id="statRoomsLabel" styleClass="stat-value-green" text="0" />
            </VBox>
            <VBox spacing="4" styleClass="stat-card">
                <Label styleClass="stat-title" text="Active Reservations" />
                <Label fx:id="statResLabel" styleClass="stat-value" text="0" />
            </VBox>

            <Region VBox.vgrow="ALWAYS" />
            <Label fx:id="feedbackLabel" styleClass="error-label" wrapText="true" />
        </VBox>

        <VBox spacing="20.0" HBox.hgrow="ALWAYS" style="-fx-padding: 24;">
            <HBox alignment="CENTER_LEFT" spacing="15.0">
                <VBox HBox.hgrow="ALWAYS">
                    <Label fx:id="contentTitle" styleClass="page-title" text="Manage Reservations" />
                    <Label styleClass="page-subtitle" text="View details and process guest arrivals/departures" />
                </VBox>
                <TextField fx:id="searchField" onKeyReleased="#handleSearch" prefWidth="250" promptText="🔍 Search current view..." styleClass="search-field" />
            </HBox>

            <TableView fx:id="mainTable" styleClass="data-table" VBox.vgrow="ALWAYS" />

            <HBox fx:id="actionBox" alignment="CENTER_RIGHT" spacing="15" styleClass="form-section">
                <padding>
                    <Insets bottom="15" left="20" right="20" top="15" />
                </padding>
                <Button onAction="#handleCheckIn" styleClass="btn-primary" text="📥 Check-In Guest" />

                <Separator orientation="VERTICAL" />

                <Label text="Payment Method:" styleClass="field-label" />
                <ComboBox fx:id="paymentMethodBox" promptText="Select Method" styleClass="role-combo" />
                <Button onAction="#handleCheckOut" styleClass="btn-primary" text="📤 Check-Out &amp; Pay" style="-fx-background-color: #16a34a;" />
            </HBox>
        </VBox>
    </HBox>
</VBox>