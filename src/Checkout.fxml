<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" alignment="TOP_CENTER" stylesheets="@hotel.css"
      xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25"
      fx:controller="CheckoutPaymentController" styleClass="root-vbox">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Checkout &amp; Payment" styleClass="page-title"/>

    <StackPane styleClass="form-section">
        <TextArea fx:id="invoiceTextArea" editable="false" prefHeight="180"
                  promptText="Your invoice details will appear here..."/>
    </StackPane>

    <HBox spacing="15" alignment="CENTER_LEFT">
        <Label text="Select Payment Method:" styleClass="field-label"/>
        <ComboBox fx:id="paymentMethodBox" promptText="Choose Method" prefWidth="180" styleClass="role-combo"/>
    </HBox>

    <HBox spacing="20" alignment="CENTER_RIGHT">
        <Button text="Back" onAction="#handleBack" styleClass="btn-secondary"/>
        <Button fx:id="confirmButton" text="Confirm Payment" onAction="#handleConfirmPayment" styleClass="btn-primary"/>
    </HBox>

</VBox>
